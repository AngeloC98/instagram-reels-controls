{
  "manifest_version": 3,
  "name": "Instagram Reels Controls",
  "version": "1.0.0",
  "description": "Adds standard media controls to Instagram Reels.",
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://www.instagram.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
