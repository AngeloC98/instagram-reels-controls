{
  "name": "instagram-reels-controls",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "npm run build:firefox && npm run build:chrome",
    "build:firefox": "vite build -- --target=firefox",
    "build:chrome": "vite build -- --target=chrome",
    "zip:firefox": "tsx scripts/zip.ts firefox",
    "zip:chrome": "tsx scripts/zip.ts chrome",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src scripts vite.config.ts vitest.config.ts && prettier --check src scripts vite.config.ts vitest.config.ts content.css",
    "format": "prettier --write src scripts vite.config.ts vitest.config.ts content.css",
    "icons": "tsx scripts/generate-icons.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.39",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
